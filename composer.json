{
  "name": "kyvshield/rest-sdk",
  "description": "KyvShield REST KYC API SDK for PHP — typed, self-contained, zero dependencies",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "KyvShield\\": "php/src/"
    }
  },
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "homepage": "https://github.com/moussa-innolink/kyv_shield_restfull",
  "keywords": ["kyc", "identity-verification", "kyvshield", "ocr", "liveness"]
}
