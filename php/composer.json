{
    "name": "kyvshield/php-sdk",
    "description": "Official PHP SDK for the KyvShield REST KYC API",
    "type": "library",
    "license": "MIT",
    "keywords": ["kyc", "liveness", "identity", "verification", "kyvshield"],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "KyvShield\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KyvShield\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
